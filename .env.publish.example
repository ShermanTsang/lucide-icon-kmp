# Copy this file to .env.publish and pass it to act with:
# act workflow_dispatch -W .github/workflows/publish-maven.yml --env-file .env.publish --secret-file .secrets.publish
# MAVEN_REPOSITORY_URL is required because publish-maven.yml always validates remote publish settings.
ACT=true
ORG_GRADLE_PROJECT_VERSION_NAME=0.1.0
MAVEN_REPOSITORY_URL=https://your.maven.repo/repository/releases

# Optional: override publish coordinates locally if needed.
# ORG_GRADLE_PROJECT_GROUP=io.github.yourname

# Optional: use a snapshot repository instead of releases.
# MAVEN_REPOSITORY_URL=https://your.maven.repo/repository/snapshots
