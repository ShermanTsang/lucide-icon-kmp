# Copy this file to .secrets.publish and pass it to act with:
# act workflow_dispatch -W .github/workflows/publish-maven.yml --env-file .env.publish --secret-file .secrets.publish
# Signing values are optional, but if one is set the other must also be set.
# SIGNING_KEY_BASE64 must contain the Base64-encoded ASCII-armored private key as a single line.
MAVEN_USERNAME=your_username
MAVEN_PASSWORD=your_password

# Optional: provide PGP signing only if your Maven repository requires signed artifacts.
SIGNING_KEY_BASE64=REPLACE_WITH_BASE64_OF_YOUR_ARMORED_PRIVATE_KEY
SIGNING_PASSWORD=your_signing_password
